// SAMS — Production SaaS schema (MySQL)
generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ACADEMY_ADMIN
  COACH
}

enum SubscriptionTier {
  FREE
  PRO
  PLUS
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum AcademyStatus {
  PENDING
  ACTIVE
  SUSPENDED
  EXPIRED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
  HALF_DAY
}

enum CoachAttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum ReceiptStatus {
  PENDING
  COMPLETED
  FAILED
  VOID
}

enum AttributeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  DUE_FEE
  OVERDUE_FEE
  COACH_ABSENT
  SUBSCRIPTION_EXPIRY
  NEW_STUDENT
  ATTENDANCE_REMINDER
  PERFORMANCE_REMINDER
  ATTRIBUTE_REQUEST
  GENERAL
}

// ─── Platform ────────────────────────────────────────────────────────────────

model SuperAdmin {
  super_admin_id Int      @id @default(autoincrement())
  name           String
  email          String   @unique
  password_hash  String
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@map("super_admins")
}

model PlatformPlan {
  plan_id       Int              @id @default(autoincrement())
  tier          SubscriptionTier @unique
  name          String
  max_coaches   Int?
  max_students  Int?
  price_monthly Decimal          @default(0) @db.Decimal(10, 2)
  is_active     Boolean          @default(true)
  created_at    DateTime         @default(now())
  updated_at    DateTime         @updatedAt

  @@map("platform_plans")
}

// ─── Academy (tenant) ────────────────────────────────────────────────────────

model Academy {
  academy_id               Int              @id @default(autoincrement())
  name                     String
  owner_name               String?
  email                    String?          @unique
  phone_number             String?
  address                  String?          @db.Text
  city                     String?
  state                    String?
  country                  String?
  pincode                  String?
  latitude                 Decimal?         @db.Decimal(10, 7)
  longitude                Decimal?         @db.Decimal(10, 7)
  logo_url                 String?
  subscription_tier        SubscriptionTier @default(FREE)
  subscription_plan        String?          // legacy string field
  subscription_starts_at   DateTime?
  subscription_expires_at  DateTime?
  status                   AcademyStatus    @default(PENDING)
  registration_fee_default Decimal          @default(0) @db.Decimal(10, 2)
  attendance_radius_meters Int              @default(100)
  receipt_template         String?          @db.Text
  notification_prefs       String?          @db.Text
  created_at               DateTime         @default(now())
  updated_at               DateTime         @updatedAt

  users               User[]
  coaches             Coach[]
  sports              Sport[]
  duration_plans      DurationPlan[]
  batches             Batch[]
  students            Student[]
  receipts            Receipt[]
  student_attendances StudentAttendance[]
  coach_attendances   CoachAttendance[]
  performance_attributes PerformanceAttribute[]
  performance_scores   PerformanceScore[]
  notifications       Notification[]
  audit_logs          AuditLog[]
  enquiries           Enquiry[]
  enrollments         StudentEnrollment[]

  @@map("academies")
}

model User {
  user_id       Int       @id @default(autoincrement())
  academy_id    Int?
  name          String
  first_name    String?
  middle_name   String?
  last_name     String?
  email         String    @unique
  password_hash String
  role          UserRole  @default(ACADEMY_ADMIN)
  is_deleted    Boolean   @default(false)
  deleted_at    DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  academy           Academy?          @relation(fields: [academy_id], references: [academy_id], onDelete: Cascade)
  marked_attendances CoachAttendance[]
  approved_receipts  Receipt[]         @relation("ReceiptApprovedBy")

  @@index([academy_id])
  @@map("users")
}

model Coach {
  coach_id       Int          @id @default(autoincrement())
  academy_id     Int
  name           String
  first_name     String?
  middle_name    String?
  last_name      String?
  specialization String?
  phone_number   String?
  email          String?
  password_hash  String?
  status         RecordStatus @default(ACTIVE)
  is_deleted     Boolean      @default(false)
  deleted_at     DateTime?
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt

  academy             Academy                @relation(fields: [academy_id], references: [academy_id], onDelete: Cascade)
  batch_assignments   BatchCoach[]
  student_attendances StudentAttendance[]
  coach_attendances   CoachAttendance[]
  collected_receipts  Receipt[]              @relation("ReceiptCollectedBy")
  performance_attrs   PerformanceAttribute[] @relation("AttrRequestedBy")
  performance_scores  PerformanceScore[]
  enrollments         StudentEnrollment[]

  @@unique([academy_id, email])
  @@map("coaches")
}

// ─── Sports & plans ──────────────────────────────────────────────────────────

model Sport {
  sport_id    Int          @id @default(autoincrement())
  name        String
  description String?      @db.Text
  base_fee    Decimal      @default(0) @db.Decimal(10, 2)
  status      RecordStatus @default(ACTIVE)
  academy_id  Int?
  is_custom   Boolean      @default(false)
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt

  academy      Academy?              @relation(fields: [academy_id], references: [academy_id], onDelete: Cascade)
  batches      Batch[]
  students     Student[]
  enrollments  StudentEnrollment[]
  perf_attrs   PerformanceAttribute[]

  @@unique([name, academy_id])
  @@index([academy_id])
  @@map("sports")
}

/// Duration plans (1/3/6/12 months) — separate from subscription tiers
model DurationPlan {
  plan_id         Int          @id @default(autoincrement())
  academy_id      Int
  name            String
  duration_months Int
  multiplier      Decimal      @default(1) @db.Decimal(5, 2)
  status          RecordStatus @default(ACTIVE)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  academy     Academy             @relation(fields: [academy_id], references: [academy_id], onDelete: Cascade)
  enrollments StudentEnrollment[]

  @@index([academy_id])
  @@map("duration_plans")
}

// ─── Batches ─────────────────────────────────────────────────────────────────

model Batch {
  batch_id     Int          @id @default(autoincrement())
  academy_id   Int
  name         String
  sport_id     Int?
  timing       String?
  start_time   String?
  end_time     String?
  max_capacity Int?
  status       RecordStatus @default(ACTIVE)
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt

  academy             Academy             @relation(fields: [academy_id], references: [academy_id], onDelete: Cascade)
  sport               Sport?              @relation(fields: [sport_id], references: [sport_id])
  coaches             BatchCoach[]
  students            Student[]
  student_attendances StudentAttendance[]
  enrollments         StudentEnrollment[]
  performance_scores  PerformanceScore[]

  @@index([academy_id])
  @@index([sport_id])
  @@map("batches")
}

model BatchCoach {
  batch_coach_id Int      @id @default(autoincrement())
  batch_id       Int
  coach_id       Int
  created_at     DateTime @default(now())

  batch Batch @relation(fields: [batch_id], references: [batch_id], onDelete: Cascade)
  coach Coach @relation(fields: [coach_id], references: [coach_id], onDelete: Cascade)

  @@unique([batch_id, coach_id])
  @@map("batch_coaches")
}

// ─── Students & enrollment ───────────────────────────────────────────────────

model Student {
  student_id    Int          @id @default(autoincrement())
  academy_id    Int
  name          String
  first_name    String?
  middle_name   String?
  last_name     String?
  phone         String?
  parent_name   String?
  parent_phone  String?
  parent_email  String?
  joining_date  DateTime?    @db.Date
  age           Int?
  gender        String?
  sport_id      Int?
  batch_id      Int?
  blood_group   String?
  fees_status   String       @default("unpaid")
  status        RecordStatus @default(ACTIVE)
  exit_reason   String?
  exit_note     String?      @db.Text
  is_deleted    Boolean      @default(false)
  deleted_at    DateTime?
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt

  academy             Academy             @relation(fields: [academy_id], references: [academy_id], onDelete: Cascade)
  sport               Sport?              @relation(fields: [sport_id], references: [sport_id])
  batch               Batch?              @relation(fields: [batch_id], references: [batch_id])
  enrollments         StudentEnrollment[]
  receipts            Receipt[]
  student_attendances StudentAttendance[]
  performance_scores  PerformanceScore[]

  @@index([academy_id])
  @@index([batch_id])
  @@map("students")
}

model StudentEnrollment {
  enrollment_id      Int       @id @default(autoincrement())
  academy_id         Int
  student_id         Int
  sport_id           Int
  duration_plan_id   Int?
  batch_id           Int?
  coach_id           Int?
  registration_fee   Decimal   @default(0) @db.Decimal(10, 2)
  sports_fee         Decimal   @default(0) @db.Decimal(10, 2)
  additional_charges Decimal   @default(0) @db.Decimal(10, 2)
  discount           Decimal   @default(0) @db.Decimal(10, 2)
  final_fee          Decimal   @default(0) @db.Decimal(10, 2)
  paid_amount        Decimal   @default(0) @db.Decimal(10, 2)
  next_due_date      DateTime? @db.Date
  is_active          Boolean   @default(true)
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  academy       Academy       @relation(fields: [academy_id], references: [academy_id], onDelete: Cascade)
  student       Student       @relation(fields: [student_id], references: [student_id], onDelete: Cascade)
  sport         Sport         @relation(fields: [sport_id], references: [sport_id], onDelete: Cascade)
  duration_plan DurationPlan? @relation(fields: [duration_plan_id], references: [plan_id])
  batch         Batch?        @relation(fields: [batch_id], references: [batch_id])
  coach         Coach?        @relation(fields: [coach_id], references: [coach_id])

  @@index([student_id])
  @@index([academy_id, next_due_date])
  @@map("student_enrollments")
}

// ─── Accounts (receipts) ─────────────────────────────────────────────────────

model Receipt {
  receipt_id            Int           @id @default(autoincrement())
  receipt_number        String        @unique
  academy_id            Int
  student_id            Int
  amount                Decimal       @db.Decimal(10, 2)
  discount              Decimal       @default(0) @db.Decimal(10, 2)
  additional_charges    Decimal       @default(0) @db.Decimal(10, 2)
  payment_date          DateTime
  method                String?
  status                ReceiptStatus @default(PENDING)
  proof_url             String?
  remarks               String?       @db.Text
  rejected_reason       String?       @db.Text
  approved_by_user_id   Int?
  collected_by_coach_id Int?
  pdf_url               String?
  created_at            DateTime      @default(now())
  updated_at            DateTime      @updatedAt

  academy       Academy @relation(fields: [academy_id], references: [academy_id], onDelete: Cascade)
  student       Student @relation(fields: [student_id], references: [student_id], onDelete: Cascade)
  approved_by   User?   @relation("ReceiptApprovedBy", fields: [approved_by_user_id], references: [user_id])
  collected_by  Coach?  @relation("ReceiptCollectedBy", fields: [collected_by_coach_id], references: [coach_id])

  @@index([academy_id])
  @@index([student_id])
  @@map("receipts")
}

// ─── Attendance ────────────────────────────────────────────────────────────────

model StudentAttendance {
  attendance_id      Int              @id @default(autoincrement())
  academy_id         Int
  student_id         Int
  batch_id           Int
  date               DateTime         @db.Date
  status             AttendanceStatus
  marked_by_coach_id Int?
  remarks            String?          @db.Text
  latitude           Decimal?         @db.Decimal(10, 7)
  longitude          Decimal?         @db.Decimal(10, 7)
  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt

  academy Academy @relation(fields: [academy_id], references: [academy_id], onDelete: Cascade)
  student Student @relation(fields: [student_id], references: [student_id], onDelete: Cascade)
  batch   Batch   @relation(fields: [batch_id], references: [batch_id], onDelete: Cascade)
  coach   Coach?  @relation(fields: [marked_by_coach_id], references: [coach_id])

  @@unique([student_id, batch_id, date])
  @@index([academy_id, date])
  @@map("student_attendance")
}

model CoachAttendance {
  attendance_id      Int                   @id @default(autoincrement())
  coach_id           Int
  academy_id         Int
  date               DateTime              @db.Date
  status             CoachAttendanceStatus
  marked_by_admin_id Int?
  latitude           Decimal?              @db.Decimal(10, 7)
  longitude          Decimal?              @db.Decimal(10, 7)
  remarks            String?               @db.Text
  created_at         DateTime              @default(now())
  updated_at         DateTime              @updatedAt

  coach   Coach   @relation(fields: [coach_id], references: [coach_id], onDelete: Cascade)
  academy Academy @relation(fields: [academy_id], references: [academy_id], onDelete: Cascade)
  admin   User?   @relation(fields: [marked_by_admin_id], references: [user_id])

  @@unique([coach_id, date])
  @@map("coach_attendance")
}

// ─── Performance tracker ───────────────────────────────────────────────────────

model PerformanceAttribute {
  attribute_id          Int                    @id @default(autoincrement())
  academy_id            Int
  sport_id              Int
  name                  String
  status                AttributeRequestStatus @default(PENDING)
  requested_by_coach_id Int?
  reviewed_at           DateTime?
  created_at            DateTime               @default(now())
  updated_at            DateTime               @updatedAt

  academy      Academy @relation(fields: [academy_id], references: [academy_id], onDelete: Cascade)
  sport        Sport   @relation(fields: [sport_id], references: [sport_id], onDelete: Cascade)
  requested_by Coach?  @relation("AttrRequestedBy", fields: [requested_by_coach_id], references: [coach_id])
  scores       PerformanceScore[]

  @@unique([sport_id, name, academy_id])
  @@map("performance_attributes")
}

model PerformanceScore {
  score_id     Int      @id @default(autoincrement())
  academy_id   Int
  student_id   Int
  attribute_id Int
  coach_id     Int
  batch_id     Int?
  score        Int
  notes        String?  @db.Text
  scored_at    DateTime @default(now())
  created_at   DateTime @default(now())

  academy   Academy              @relation(fields: [academy_id], references: [academy_id], onDelete: Cascade)
  student   Student              @relation(fields: [student_id], references: [student_id], onDelete: Cascade)
  attribute PerformanceAttribute @relation(fields: [attribute_id], references: [attribute_id], onDelete: Cascade)
  coach     Coach                @relation(fields: [coach_id], references: [coach_id], onDelete: Cascade)
  batch     Batch?               @relation(fields: [batch_id], references: [batch_id], onDelete: Cascade)

  @@index([student_id, attribute_id])
  @@index([batch_id])
  @@map("performance_scores")
}

// ─── Enquiries ───────────────────────────────────────────────────────────────

model Enquiry {
  enquiry_id Int      @id @default(autoincrement())
  academy_id Int?
  name       String
  email      String
  phone      String?
  subject    String
  message    String   @db.Text
  status     String   @default("New")
  remarks    String?  @db.Text
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  academy Academy? @relation(fields: [academy_id], references: [academy_id], onDelete: Cascade)

  @@index([academy_id, created_at])
  @@map("enquiries")
}

// ─── Notifications & audit ─────────────────────────────────────────────────────

model Notification {
  notification_id Int              @id @default(autoincrement())
  academy_id      Int?
  user_id         Int?
  coach_id        Int?
  type            NotificationType
  title           String
  body            String           @db.Text
  is_read         Boolean          @default(false)
  metadata        String?          @db.Text
  created_at      DateTime         @default(now())

  academy Academy? @relation(fields: [academy_id], references: [academy_id], onDelete: Cascade)

  @@index([academy_id, is_read])
  @@map("notifications")
}

model AuditLog {
  audit_id    Int      @id @default(autoincrement())
  academy_id  Int?
  actor_type  String
  actor_id    Int?
  action      String
  entity_type String?
  entity_id   Int?
  metadata    String?  @db.Text
  ip_address  String?
  created_at  DateTime @default(now())

  academy Academy? @relation(fields: [academy_id], references: [academy_id])

  @@index([academy_id, created_at])
  @@map("audit_logs")
}

// ─── System Configurations ───────────────────────────────────────────────────

model GlobalSetting {
  setting_id    Int      @id @default(autoincrement())
  setting_key   String   @unique
  setting_value String   @db.Text
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("global_settings")
}

model PasswordReset {
  reset_id     Int      @id @default(autoincrement())
  email        String
  code_hash    String
  account_type String
  expires_at   DateTime
  created_at   DateTime @default(now())

  @@index([email])
  @@map("password_resets")
}